# DeepSeek API key. The server reads `deepseek_KEY` (note the capitalized KEY)
# to match the user's existing shell export, and also falls back to DEEPSEEK_API_KEY.
deepseek_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk-...

# DeepSeek API base + models
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Server
PORT=8787
# Current teaching workspace root.
WAC_WORKSPACE_ROOT=./examples/buggy-ts-project
# JSON session log path used by packages/telemetry.
WAC_SESSION_LOG_PATH=./data/session-log.json
# Use mock by default. Set to openai_compatible to call DeepSeek/OpenAI-compatible APIs.
MODEL_PROVIDER=mock
